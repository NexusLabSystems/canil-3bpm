{
  "name": "canil-3bpm",
  "private": true,
  "workspaces": [
    "backend",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n backend,web -c blue,green \"npm run dev:backend\" \"npm run dev:web\"",
    "dev:backend": "npm run start:dev --workspace backend",
    "dev:web": "npm run dev --workspace web"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
